# Copy this to .env and fill in your values
# NEVER commit .env to version control

# JWT signing secret — long random string (32+ chars)
JWT_SECRET=replace_with_a_long_random_secret_string

# JWT expiry
JWT_EXPIRY=365d

# MySQL (from cPanel)
DB_HOST=localhost
DB_NAME=your_cpanel_db_name
DB_USER=your_cpanel_db_user
DB_PASS=your_cpanel_db_password
DB_PORT=3306

# App port (cPanel sets this automatically in production)
PORT=3000

# Your frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# Seed accounts — fill before running: npm run seed
# Passwords must be at least 8 characters
SEED_USER_A_NAME=Your Name
SEED_USER_A_EMAIL=you@example.com
SEED_USER_A_PASSWORD=changeme1

SEED_USER_B_NAME=Partner Name
SEED_USER_B_EMAIL=partner@example.com
SEED_USER_B_PASSWORD=changeme2
